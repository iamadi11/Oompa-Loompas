{
  "name": "@oompa/web",
  "version": "0.4.3",
  "private": true,
  "description": "Oompa Loompas — Web App",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3005",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "verify:pwa": "node scripts/check-pwa-files.mjs",
    "bones:build": "node ./scripts/bones-build.mjs"
  },
  "dependencies": {
    "@oompa/types": "workspace:*",
    "@oompa/utils": "workspace:*",
    "boneyard-js": "^1.6.3",
    "motion": "^12.38.0",
    "next": "^16.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@oompa/config": "workspace:*",
    "@serwist/turbopack": "^9.5.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.2",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.3",
    "serwist": "^9.5.7",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
