# Server-side rewrites: browser calls /api/v1/* on the Next origin; Next proxies here.
API_URL=http://localhost:3001

# Optional — only when the JSON client must talk to another origin (cookies won’t apply unless CORS + credentials are aligned).
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Must match API SESSION_COOKIE_NAME when overridden (default oompa_session).
# NEXT_PUBLIC_SESSION_COOKIE_NAME=oompa_session
