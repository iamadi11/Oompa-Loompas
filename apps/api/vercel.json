{
  "framework": null,
  "installCommand": "cd ../.. && NODE_ENV=development pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @oompa/db build",
  "outputDirectory": ".",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
