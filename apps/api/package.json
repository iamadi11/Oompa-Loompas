{
  "name": "@oompa/api",
  "version": "0.4.5",
  "private": true,
  "description": "Fastify REST API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.3",
    "@oompa/db": "workspace:*",
    "@oompa/types": "workspace:*",
    "@oompa/utils": "workspace:*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@oompa/config": "workspace:*",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.4"
  }
}
