{
  "name": "@oompa/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify REST API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "@oompa/db": "workspace:*",
    "@oompa/types": "workspace:*",
    "@oompa/utils": "workspace:*",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@oompa/config": "workspace:*",
    "@types/node": "^20.16.5",
    "@vitest/coverage-v8": "^2.0.5",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
