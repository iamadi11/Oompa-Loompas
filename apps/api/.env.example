# Works with: docker compose -f infra/docker-compose.postgres.yml up -d
# Homebrew Postgres: use your macOS username, e.g. postgresql://you@localhost:5432/oompa_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oompa_dev
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
# Must match the origin where @oompa/web runs (port 3000 or 3005 for `dev:clean`).
WEB_URL=http://localhost:3000
NODE_ENV=development

# Optional — payment milestone invoices (HTML). Sequential numbers are stored on first open.
# INVOICE_DOCUMENT_LABEL=Tax invoice
# INVOICE_ISSUER_LEGAL_NAME=Your registered business name
# INVOICE_ISSUER_ADDRESS=Line 1|Line 2|Postal code, City
# INVOICE_ISSUER_TAX_IDS=GSTIN: 22AAAAA0000A1Z5
# INVOICE_ISSUER_EMAIL=billing@example.com
# INVOICE_PLACE_OF_SUPPLY=State or country (place of supply)

# Session auth (required in production — min 32 chars)
# SESSION_SECRET=generate-a-long-random-string-at-least-32-chars
# SESSION_COOKIE_NAME=oompa_session
# SESSION_TTL_DAYS=14

# Seed-only admin (required when DB has no deals — never commit real values)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-in-dev-only
