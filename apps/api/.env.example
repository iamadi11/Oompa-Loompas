# Works with: docker compose -f infra/docker-compose.postgres.yml up -d
# Homebrew Postgres: use your macOS username, e.g. postgresql://you@localhost:5432/oompa_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oompa_dev
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
WEB_URL=http://localhost:3000
NODE_ENV=development
