{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["code-review-graph"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Library/Frameworks/Python.framework/Versions/3.12/bin/code-review-graph update",
            "timeout": 8000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Library/Frameworks/Python.framework/Versions/3.12/bin/code-review-graph status --json",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
