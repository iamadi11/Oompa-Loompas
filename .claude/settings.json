{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["code-review-graph"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "/Library/Frameworks/Python.framework/Versions/3.12/bin/code-review-graph update --quiet",
        "timeout": 8000
      }
    ],
    "SessionStart": [
      {
        "command": "/Library/Frameworks/Python.framework/Versions/3.12/bin/code-review-graph status --json",
        "timeout": 5000
      }
    ],
    "PreCommit": [
      {
        "command": "/Library/Frameworks/Python.framework/Versions/3.12/bin/code-review-graph detect-changes --brief",
        "timeout": 15000
      }
    ]
  }
}
