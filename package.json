{
  "name": "oompa-loompas",
  "version": "0.5.3",
  "private": true,
  "description": "Oompa Loompas — creator financial outcome engine (monorepo)",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "test": "pnpm -r --filter='!@oompa/e2e' test",
    "test:e2e": "pnpm -C apps/e2e run test",
    "test:e2e:ui": "pnpm -C apps/e2e run test:ui",
    "test:e2e:headed": "pnpm -C apps/e2e run test:headed",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check:workspace": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,md}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:use-local-pg": "node scripts/use-local-postgres-url.cjs",
    "boundary:check": "depcruise --config .dependency-cruiser.cjs apps/api/src apps/web"
  },
  "devDependencies": {
    "dependency-cruiser": "^17.3.10",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9"
}
