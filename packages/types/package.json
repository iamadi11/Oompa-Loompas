{
  "name": "@oompa/types",
  "version": "0.2.1",
  "private": true,
  "description": "Shared TypeScript types and Zod schemas",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@oompa/config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
