{
  "name": "@oompa/db",
  "version": "0.2.0",
  "private": true,
  "description": "Database layer — Prisma client and schema",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && pnpm prisma generate",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../apps/api/.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../apps/api/.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../apps/api/.env -- prisma studio",
    "db:seed": "dotenv -e ../../apps/api/.env -- tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@oompa/config": "workspace:*",
    "@types/node": "^22.15.3",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.18.0",
    "tsx": "^4.17.0",
    "typescript": "^5.9.3"
  }
}
