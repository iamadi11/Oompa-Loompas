generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(320)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  roles        Role[]    @default([MEMBER])
  sessions     Session[]
  deals        Deal[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}

enum DealStatus {
  DRAFT
  NEGOTIATING
  ACTIVE
  DELIVERED
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  RECEIVED
  OVERDUE
  REFUNDED
}

enum Currency {
  INR
  USD
  EUR
  GBP
}

enum DeliverableStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum DeliverablePlatform {
  INSTAGRAM
  YOUTUBE
  TWITTER
  LINKEDIN
  PODCAST
  BLOG
  OTHER
}

enum DeliverableType {
  POST
  REEL
  STORY
  VIDEO
  INTEGRATION
  MENTION
  ARTICLE
  OTHER
}

model Deal {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String     @db.VarChar(255)
  brandName String     @map("brand_name") @db.VarChar(255)
  value     Decimal    @db.Decimal(15, 2)
  currency  Currency   @default(INR)
  status    DealStatus @default(DRAFT)
  startDate DateTime?  @map("start_date")
  endDate   DateTime?  @map("end_date")
  notes     String?    @db.Text

  payments     Payment[]
  deliverables Deliverable[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([brandName])
  @@index([createdAt(sort: Desc)])
  @@map("deals")
}

model Payment {
  id            String        @id @default(uuid())
  dealId        String        @map("deal_id")
  deal          Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  amount        Decimal       @db.Decimal(15, 2)
  currency      Currency      @default(INR)
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime?     @map("due_date")
  receivedAt    DateTime?     @map("received_at")
  notes         String?       @db.Text
  invoiceNumber String?       @unique @map("invoice_number") @db.VarChar(32)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dealId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

model InvoiceCounter {
  id      String @id
  lastSeq Int    @default(0) @map("last_seq")

  @@map("invoice_counters")
}

model Deliverable {
  id          String              @id @default(uuid())
  dealId      String              @map("deal_id")
  deal        Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title       String              @db.VarChar(255)
  platform    DeliverablePlatform
  type        DeliverableType
  dueDate     DateTime?           @map("due_date")
  status      DeliverableStatus   @default(PENDING)
  completedAt DateTime?           @map("completed_at")
  notes       String?             @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dealId])
  @@index([status])
  @@index([dueDate])
  @@map("deliverables")
}
